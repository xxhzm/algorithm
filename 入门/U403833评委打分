#include <stdio.h>

int main(){
	long long n;
	scanf("%lld", &n);
	int arr[n], i, max = 0, min, sum, j, s[n];
	for(i = 0;i < n;i++){
		scanf("%d", &arr[i]);
		if(i == 0){
			min = arr[0];	
		}
		if(arr[i] > max){
			max = arr[i];
		}
		if(arr[i] < min){
			min = arr[i];
		}
		if(i == 0){
			s[0] = arr[0];
		}else{
			s[i] = s[i - 1] + arr[i];
		}
		
		if(i >= 2){
			printf("%.2f\n", (s[i] - min - max) / ((i - 1) * 1.0));
		}
	}
	return 0;
}
